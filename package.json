{
  "name": "psych-scribe",
  "version": "2.2.0",
  "description": "Psychiatric documentation assistant for PMHNPs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg",
    "build:zip": "electron-builder --mac zip"
  },
  "author": "Lorenzo Hatten",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@anthropic-ai/sdk": "^0.26.0",
    "form-data": "^4.0.0",
    "openai": "^4.0.0",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.7.0"
  },
  "build": {
    "appId": "com.lorenzohatten.psych-scribe",
    "productName": "Psych Scribe",
    "mac": {
      "category": "public.app-category.medical",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "icon.icns",
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Psych Scribe needs microphone access to transcribe clinical sessions via Whisper."
      },
      "identity": null,
      "hardenedRuntime": false
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "renderer.js",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    }
  }
}